# ──────────────────────────────────────────────
# Neo4j Agent — Environment Configuration
# Copy this file to .env and fill in real values
# ──────────────────────────────────────────────

# ── Neo4j ──────────────────────────────────────
# Use a READ-ONLY Neo4j user here for safety
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j_readonly
NEO4J_PASSWORD=your_readonly_password
NEO4J_DATABASE=neo4j
# Set to true ONLY for managed cloud (AuraDB) where cert chain
# verification fails. Never enable for self-hosted Neo4j.
NEO4J_SKIP_TLS_VERIFY=false

# ── Ollama (local LLM) ─────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:latest
OLLAMA_TEMPERATURE=0.0

# ── Redis ──────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Cache TTLs (seconds) ───────────────────────
# How long to cache the Neo4j graph schema in Redis
SCHEMA_CACHE_TTL_SECONDS=300
# How long to cache identical LLM responses in Redis
LLM_CACHE_TTL_SECONDS=3600

# ── Application ────────────────────────────────
APP_NAME=Neo4j Agent
DEBUG=false
LOG_LEVEL=INFO

# ── Security ──────────────────────────────────
# API key for authenticating requests. Leave empty to disable (dev only).
API_KEY=
# Comma-separated list of allowed CORS origins. Empty = none in production.
CORS_ORIGINS=

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_CHAT=10/minute
RATE_LIMIT_GENERAL=30/minute

# ── MCP Server ────────────────────────────────
MCP_PATH=/mcp
